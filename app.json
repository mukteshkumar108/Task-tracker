{
  "expo": {
    "name": "Task Tracker",
    "slug": "task-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "tasktracker",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
